# cp e2e/.env.test.example e2e/.env.test.local して値を埋め、
# `set -a; source e2e/.env.test.local; set +a` などで読み込んでから
# npm run test:e2e を実行する。
#
# ここに指定するのは「E2E専用に用意したテストアカウント」を強く推奨する。
# post-flow / community-flow specは実際に投稿・コミュニティ作成を行うため、
# 本番相当のDBに繋ぐ場合は影響範囲を理解した上で実行すること。

PLAYWRIGHT_BASE_URL=http://localhost:5173

E2E_USER_EMAIL=e2e-user@example.com
E2E_USER_PASSWORD=change-me

E2E_ADMIN_EMAIL=e2e-admin@example.com
E2E_ADMIN_PASSWORD=change-me
